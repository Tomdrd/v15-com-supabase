{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*\\.(?:js|css|webp|png|jpg|jpeg|gif|ico|svg|woff2|woff|ttf|mp3|json))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, stale-while-revalidate=60" }
      ]
    }
  ]
}